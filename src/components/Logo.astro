---
interface Props {
  size?: number;
  class?: string;
}
const { size = 22, class: className = '' } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  class={className}
  aria-hidden="true"
>
  <rect x="22" y="4" width="20" height="16" rx="4" fill="#2D8CFF" />
  <path d="M32 20 L32 30" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
  <path d="M14 30 L50 30" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
  <path d="M14 30 L14 40" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
  <path d="M50 30 L50 40" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
  <rect x="4" y="40" width="20" height="16" rx="4" fill="#34C759" />
  <rect x="40" y="40" width="20" height="16" rx="4" fill="#7B61FF" />
</svg>
