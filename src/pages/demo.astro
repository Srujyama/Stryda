---
import Base from '../layouts/Base.astro';

// Replace with a Formspree endpoint to deliver to inbox.
// Until set, the form submits via mailto: to FALLBACK_EMAIL.
const FORMSPREE_ENDPOINT = '';
const FALLBACK_EMAIL = 'bobbyzli@berkeley.edu';
const formAction = FORMSPREE_ENDPOINT || `mailto:${FALLBACK_EMAIL}`;
---
<Base
  title="Request a demo — Stryda"
  description="Pick a real mandate. Bring the documents. We'll show you a live ingestion and a draft set of outputs in under an hour."
>
  <section class="sec-first">
    <div class="container">
      <p class="eyebrow">Request a demo</p>
      <h1 class="h-1" style="margin-top: var(--s-4); max-width: 18ch;">
        Bring a deal. See it shipped.
      </h1>
      <p style="margin-top: var(--s-7); font-size: 18px; max-width: 60ch;">
        Pick a real mandate you're working. Bring the documents. We will run a live ingestion and walk you through the draft CIM, teaser, normalized financials, and buyer list in under an hour. No prepared deck &mdash; your data, your outputs.
      </p>
    </div>
  </section>

  <section class="sec">
    <div class="container">
      <div class="demo-grid">
        <aside>
          <p class="eyebrow">What to expect</p>
          <ul class="dash-list" style="margin-top: var(--s-5);">
            <li><strong>Format.</strong> Founder-led, 30&ndash;60 minutes. Screen share. You upload one mandate; we walk through the four outputs as they generate.</li>
            <li><strong>Bring.</strong> Three to five years of P&amp;L, balance sheet, cash flow. Management deck or business overview. Prior CIM if you have one.</li>
            <li><strong>After.</strong> If it fits, we talk about the design-partner program: ninety days free, two real mandates, $2&ndash;3k per month after.</li>
          </ul>
        </aside>

        <div class="form-wrap">
          <p class="eyebrow">Your details</p>
          <h2 class="h-3" style="margin-top: var(--s-3); max-width: 24ch;">
            Tell us about your firm. We reply within one business day.
          </h2>
          <p style="margin-top: var(--s-4); color: var(--c-fg-2); font-size: 14px;">
            No newsletters. No third-party sharing. Everything stays between us.
          </p>

          <form
            class="form-stack"
            action={formAction}
            method="POST"
            {...FORMSPREE_ENDPOINT ? {} : { enctype: 'text/plain' }}
          >
            <div class="form-row two">
              <div class="field">
                <label for="firstName">First name</label>
                <input type="text" id="firstName" name="firstName" required autocomplete="given-name" />
              </div>
              <div class="field">
                <label for="lastName">Last name</label>
                <input type="text" id="lastName" name="lastName" required autocomplete="family-name" />
              </div>
            </div>

            <div class="form-row two">
              <div class="field">
                <label for="email">Work email</label>
                <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@firm.com" />
              </div>
              <div class="field">
                <label for="firm">Firm</label>
                <input type="text" id="firm" name="firm" required autocomplete="organization" />
              </div>
            </div>

            <div class="form-row two">
              <div class="field">
                <label for="role">Your role</label>
                <select id="role" name="role" required>
                  <option value="">Select&hellip;</option>
                  <option value="Partner / MD">Partner / MD</option>
                  <option value="Director / VP">Director / VP</option>
                  <option value="Associate / Analyst">Associate / Analyst</option>
                  <option value="Search fund principal">Search fund principal</option>
                  <option value="Operator / advisor">Operator / advisor</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div class="field">
                <label for="firmType">Firm type</label>
                <select id="firmType" name="firmType" required>
                  <option value="">Select&hellip;</option>
                  <option value="Boutique investment bank">Boutique investment bank</option>
                  <option value="Search fund">Search fund</option>
                  <option value="M&A advisory">M&amp;A advisory</option>
                  <option value="Family office">Family office</option>
                  <option value="Private equity">Private equity</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>

            <div class="field">
              <label for="dealsPerYear">Sell-side mandates per year</label>
              <select id="dealsPerYear" name="dealsPerYear">
                <option value="">Select&hellip;</option>
                <option value="1–5">1&ndash;5</option>
                <option value="6–15">6&ndash;15</option>
                <option value="16–30">16&ndash;30</option>
                <option value="30+">30+</option>
                <option value="Not applicable">Not applicable</option>
              </select>
            </div>

            <div class="field">
              <label for="message">Anything you want us to know? (optional)</label>
              <textarea id="message" name="message" placeholder="A live mandate you're working, sectors you cover, what you're hoping the demo answers&hellip;"></textarea>
            </div>

            <div class="submit-row">
              <button type="submit" class="btn">Send request</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .demo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-7);
  }
  @media (min-width: 1024px) {
    .demo-grid { grid-template-columns: 4fr 8fr; gap: var(--s-9); }
  }

  .form-stack {
    margin-top: var(--s-7);
    display: flex; flex-direction: column;
    gap: var(--s-5);
  }
  .form-row {
    display: grid; grid-template-columns: 1fr;
    gap: var(--s-5);
  }
  @media (min-width: 640px) {
    .form-row.two { grid-template-columns: 1fr 1fr; }
  }
  .submit-row {
    margin-top: var(--s-3);
    display: flex; gap: var(--s-5);
    align-items: center;
  }
</style>
